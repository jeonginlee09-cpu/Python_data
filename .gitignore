.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyright/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/

# Packaging artifacts
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Generated analysis and report outputs
**/output/*
!**/output/.gitkeep
*.joblib

# Jupyter
.ipynb_checkpoints/

# Environment variables and secrets
.env
.env.*
!.env.example
*.pem
*.key

# Editors and IDEs
.vscode/
.idea/
*.swp
*.swo

# OS-generated files
.DS_Store
Thumbs.db

